{
  "name": "@honua-io/embed",
  "version": "0.1.0",
  "description": "Framework-agnostic Honua embeddable map web component.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/honua-io/honua-mobile.git",
    "directory": "src/Honua.Embed"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly && node scripts/copy-cesium-assets.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "honua",
    "map",
    "scene",
    "cesium",
    "3d-tiles",
    "web-component",
    "gis"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "happy-dom": "^20.0.10",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "cesium": "^1.140.0"
  }
}
