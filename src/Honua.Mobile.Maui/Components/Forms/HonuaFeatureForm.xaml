<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="Honua.Mobile.Maui.Components.Forms.HonuaFeatureForm"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:forms="clr-namespace:Honua.Mobile.Maui.Components.Forms"
             x:Name="FeatureForm"
             x:DataType="forms:HonuaFeatureFormViewModel">

    <ContentView.Resources>
        <ResourceDictionary>
            <!-- Form Field Templates -->
            <DataTemplate x:Key="TextFieldTemplate" x:DataType="forms:IFormField">
                <StackLayout Spacing="5" Margin="0,10">
                    <Label Text="{Binding Label}"
                           FontSize="16"
                           FontAttributes="Bold">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding Label}" />
                                <Span Text=" *"
                                      TextColor="Red"
                                      IsVisible="{Binding IsRequired}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <Entry Text="{Binding Value, Mode=TwoWay}"
                           Placeholder="{Binding Placeholder}"
                           IsEnabled="{Binding IsEnabled}"
                           Keyboard="{Binding KeyboardType}">
                        <Entry.Behaviors>
                            <forms:ValidationBehavior ValidationType="{Binding ValidationType}" />
                            <toolkit:EventToCommandBehavior EventName="TextChanged"
                                                          Command="{Binding Source={x:Reference FeatureForm}, Path=BindingContext.ValidateFieldCommand}"
                                                          CommandParameter="{Binding}" />
                        </Entry.Behaviors>
                    </Entry>

                    <Label Text="{Binding ValidationMessage}"
                           TextColor="Red"
                           FontSize="12"
                           IsVisible="{Binding HasValidationError}" />

                    <Label Text="{Binding HelpText}"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                           FontSize="12"
                           IsVisible="{Binding HasHelpText}" />
                </StackLayout>
            </DataTemplate>

            <DataTemplate x:Key="PhotoFieldTemplate" x:DataType="forms:IFormField">
                <StackLayout Spacing="10" Margin="0,10">
                    <Label Text="{Binding Label}" FontSize="16" FontAttributes="Bold" />

                    <!-- Photo Capture Button -->
                    <Button Text="📷 Take Photo"
                            Command="{Binding Source={x:Reference FeatureForm}, Path=BindingContext.CapturePhotoCommand}"
                            CommandParameter="{Binding}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="8" />

                    <!-- Photo Preview Gallery -->
                    <CollectionView ItemsSource="{Binding Photos}"
                                   HeightRequest="120"
                                   IsVisible="{Binding HasPhotos}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="forms:PhotoItem">
                                <Frame CornerRadius="8" Padding="0" HasShadow="True">
                                    <Grid>
                                        <Image Source="{Binding ThumbnailPath}"
                                               Aspect="AspectFill"
                                               WidthRequest="100"
                                               HeightRequest="100" />
                                        <Button Text="✕"
                                                BackgroundColor="Red"
                                                TextColor="White"
                                                CornerRadius="15"
                                                WidthRequest="30"
                                                HeightRequest="30"
                                                FontSize="12"
                                                HorizontalOptions="End"
                                                VerticalOptions="Start"
                                                Margin="5"
                                                Command="{Binding Source={x:Reference FeatureForm}, Path=BindingContext.DeletePhotoCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="{Binding ValidationMessage}" TextColor="Red" FontSize="12" />
                </StackLayout>
            </DataTemplate>

            <DataTemplate x:Key="LocationFieldTemplate" x:DataType="forms:IFormField">
                <StackLayout Spacing="10" Margin="0,10">
                    <Label Text="{Binding Label}" FontSize="16" FontAttributes="Bold" />

                    <!-- Current Location Display -->
                    <Frame BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"
                           CornerRadius="8" Padding="15">
                        <StackLayout>
                            <Label Text="{Binding LocationText}" FontSize="14" />
                            <Label Text="{Binding AccuracyText}" FontSize="12" TextColor="{StaticResource Gray600}" />
                        </StackLayout>
                    </Frame>

                    <!-- Location Actions -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="📍 Update Location"
                                Command="{Binding Source={x:Reference FeatureForm}, Path=BindingContext.UpdateLocationCommand}"
                                CommandParameter="{Binding}"
                                FontSize="14" />
                        <Button Grid.Column="1"
                                Text="🗺️ View on Map"
                                Command="{Binding Source={x:Reference FeatureForm}, Path=BindingContext.ViewLocationCommand}"
                                CommandParameter="{Binding}"
                                FontSize="14" />
                    </Grid>

                    <Label Text="{Binding ValidationMessage}" TextColor="Red" FontSize="12" />
                </StackLayout>
            </DataTemplate>

            <!-- Field Template Selector -->
            <forms:FormFieldTemplateSelector x:Key="FieldTemplateSelector"
                                           TextTemplate="{StaticResource TextFieldTemplate}"
                                           PhotoTemplate="{StaticResource PhotoFieldTemplate}"
                                           LocationTemplate="{StaticResource LocationFieldTemplate}" />
        </ResourceDictionary>
    </ContentView.Resources>

    <ScrollView>
        <StackLayout Padding="20" Spacing="0">

            <!-- Form Header -->
            <Label Text="{Binding FormTitle}"
                   FontSize="24"
                   FontAttributes="Bold"
                   Margin="0,0,0,10" />

            <Label Text="{Binding FormDescription}"
                   FontSize="16"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                   Margin="0,0,0,20"
                   IsVisible="{Binding HasDescription}" />

            <!-- Progress Indicator -->
            <StackLayout Orientation="Horizontal"
                        HorizontalOptions="FillAndExpand"
                        Margin="0,0,0,20"
                        IsVisible="{Binding ShowProgress}">
                <Label Text="Progress:" FontSize="14" VerticalOptions="Center" />
                <ProgressBar Progress="{Binding CompletionProgress}"
                            ProgressColor="{StaticResource Primary}"
                            HorizontalOptions="FillAndExpand"
                            VerticalOptions="Center"
                            Margin="10,0" />
                <Label Text="{Binding CompletionPercentage, StringFormat='{0:F0}%'}"
                       FontSize="14"
                       VerticalOptions="Center" />
            </StackLayout>

            <!-- Dynamic Form Fields -->
            <CollectionView ItemsSource="{Binding FormFields}"
                           ItemTemplate="{StaticResource FieldTemplateSelector}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
                </CollectionView.ItemsLayout>
            </CollectionView>

            <!-- Form Actions -->
            <StackLayout Spacing="10" Margin="0,30,0,20">

                <!-- Save Draft Button -->
                <Button Text="💾 Save Draft"
                        Command="{Binding SaveDraftCommand}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                        TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                        CornerRadius="8"
                        HeightRequest="50"
                        FontSize="16"
                        IsVisible="{Binding AllowDrafts}" />

                <!-- Submit Button -->
                <Button Text="{Binding SubmitButtonText}"
                        Command="{Binding SubmitFormCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="50"
                        FontSize="16"
                        FontAttributes="Bold"
                        IsEnabled="{Binding CanSubmit}" />

                <!-- Validation Summary -->
                <Frame BackgroundColor="{StaticResource Warning}"
                       CornerRadius="8"
                       Padding="15"
                       IsVisible="{Binding HasValidationErrors}">
                    <StackLayout>
                        <Label Text="⚠️ Please fix the following errors:"
                               TextColor="White"
                               FontSize="16"
                               FontAttributes="Bold" />
                        <CollectionView ItemsSource="{Binding ValidationErrors}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Label Text="{Binding}"
                                           TextColor="White"
                                           FontSize="14"
                                           Margin="20,2,0,2" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </StackLayout>
                </Frame>

            </StackLayout>
        </StackLayout>
    </ScrollView>

</ContentView>